# Keycloak hostname (devtunnel URL or public domain)
# Example: https://abc123-8080.brs.devtunnels.ms
KC_HOSTNAME=

# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=

# Keycloak internal database
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=

# GateWise application database
GATEWISE_DB_NAME=gatewise
GATEWISE_DB_USER=gatewise
GATEWISE_DB_PASSWORD=

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=
RABBITMQ_QUEUE=user.login.sync
RABBITMQ_DLQ=user.login.sync.dlq

# External authentication API used by the Keycloak SPI
# Must be the full login endpoint URL.
API_URL=
API_AUTH_KEY=

# Keycloak theme
KC_LOGIN_THEME=gatewise
KC_THEME_REALM=master

# PEM paths (place keys in deploy/secrets/, not tracked by git)
CRYPTO_KEYS_PRIVATE_KEY_PATH=/app/secrets/private_backend.pem
CRYPTO_KEYS_ESP_PUBLIC_KEY_PATH=/app/secrets/public_esp32.pem
